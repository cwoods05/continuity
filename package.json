{
  "name": "@continuityai/cli",
  "version": "0.6.0",
  "description": "Persistent project memory for AI coding assistants. One command gives any agent your full project context.",
  "homepage": "https://github.com/cwoods05/continuity#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cwoods05/continuity"
  },
  "bugs": {
    "url": "https://github.com/cwoods05/continuity/issues"
  },
  "type": "module",
  "bin": {
    "continuity": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "developer-tools",
    "cli",
    "cursor",
    "claude",
    "copilot",
    "context",
    "memory",
    "mcp",
    "productivity"
  ],
  "author": "cwoods05",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "12"
  }
}

{
  "name": "@continuityai/cli",
  "version": "0.5.1",
  "description": "Project memory for AI-assisted software development",
  "homepage": "https://github.com/your-org/continuity",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/continuity"
  },
  "bugs": {
    "url": "https://github.com/your-org/continuity/issues"
  },
  "type": "module",
  "bin": {
    "continuity": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "ai",
    "continuity",
    "agent",
    "context"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0"
  }
}
